<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Non-sandboxed: Signr talks to the usbmuxd unix socket, which the App
	     Sandbox cannot reach. No app-sandbox key = sandbox off (like AltServer). -->
	<!-- Harmless in dev; relevant once we ship with the hardened runtime. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
